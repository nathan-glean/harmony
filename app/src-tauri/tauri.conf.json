{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "harmony",
  "version": "0.1.0",
  "identifier": "co.genio.harmony",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "harmony",
        "width": 1280,
        "height": 820,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3NTAwMEJDQkMxMEEzRkMKUldUOG94Qzh2QUJRNTA1UjZJNlc4cTVRSVQwRUVQazlVVWN4UVN1Z2FGYndYS2hjZlU2cE5qMkcK",
      "endpoints": [
        "https://github.com/nathan-glean/harmony/releases/latest/download/latest.json"
      ]
    }
  }
}
